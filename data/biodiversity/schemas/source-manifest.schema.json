{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Biodiversity Source Manifest Entry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "group",
      "role",
      "priority",
      "url",
      "access",
      "authRequired",
      "retrievalMethod",
      "license",
      "citationHint",
      "releaseCadence",
      "fieldMappingFocus",
      "rawSnapshotPath",
      "checksumRequired",
      "notes"
    ],
    "properties": {
      "id": { "type": "string" },
      "group": { "type": "string" },
      "role": { "type": "string" },
      "priority": { "type": "string", "enum": ["high", "medium", "low"] },
      "url": { "type": "string" },
      "access": { "type": "string" },
      "authRequired": { "type": "boolean" },
      "retrievalMethod": { "type": "string" },
      "license": { "type": "string" },
      "citationHint": { "type": "string" },
      "releaseCadence": { "type": "string" },
      "fieldMappingFocus": {
        "type": "array",
        "items": { "type": "string" }
      },
      "rawSnapshotPath": { "type": "string" },
      "checksumRequired": { "type": "boolean" },
      "notes": { "type": "string" }
    }
  }
}
