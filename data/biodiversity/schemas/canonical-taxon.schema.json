{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Canonical Biodiversity Taxon Record",
  "type": "object",
  "required": [
    "internalId",
    "scientificName",
    "taxonomicStatus",
    "taxonomy",
    "distribution",
    "sources",
    "provenance"
  ],
  "properties": {
    "internalId": {
      "type": "string",
      "pattern": "^[a-z0-9:_-]+$"
    },
    "scientificName": {
      "type": "string",
      "minLength": 1
    },
    "scientificNameAuthorship": {
      "type": ["string", "null"]
    },
    "acceptedName": {
      "type": ["string", "null"]
    },
    "taxonomicStatus": {
      "type": "string",
      "enum": ["accepted", "synonym", "unresolved", "curated-ui-subset"]
    },
    "commonNames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "language"],
        "properties": {
          "name": { "type": "string" },
          "language": { "type": "string" },
          "preferred": { "type": "boolean" }
        }
      }
    },
    "taxonomy": {
      "type": "object",
      "required": ["kingdom"],
      "properties": {
        "kingdom": { "type": "string" },
        "phylum": { "type": ["string", "null"] },
        "class": { "type": ["string", "null"] },
        "order": { "type": ["string", "null"] },
        "family": { "type": ["string", "null"] },
        "genus": { "type": ["string", "null"] },
        "species": { "type": ["string", "null"] },
        "rank": { "type": ["string", "null"] }
      }
    },
    "distribution": {
      "type": "object",
      "required": ["country"],
      "properties": {
        "country": { "type": "string" },
        "regions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "provinces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "presenceType": {
          "type": ["string", "null"],
          "enum": ["present", "possibly-present", "absent", "introduced", "unknown", null]
        },
        "distributionNotes": {
          "type": ["string", "null"]
        }
      }
    },
    "conservation": {
      "type": "object",
      "properties": {
        "iucnCode": {
          "type": ["string", "null"]
        },
        "iucnLabelId": {
          "type": ["string", "null"]
        },
        "populationText": {
          "type": ["string", "null"]
        },
        "threatsText": {
          "type": ["string", "null"]
        }
      }
    },
    "media": {
      "type": "object",
      "properties": {
        "imagePath": { "type": ["string", "null"] },
        "accentColor": { "type": ["string", "null"] }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sourceId", "sourceUrl", "retrievedAt"],
        "properties": {
          "sourceId": { "type": "string" },
          "sourceUrl": { "type": "string" },
          "externalId": { "type": ["string", "null"] },
          "retrievedAt": { "type": "string" },
          "license": { "type": ["string", "null"] },
          "fieldsTrusted": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["generatedAt", "pipelineStage"],
      "properties": {
        "generatedAt": { "type": "string" },
        "pipelineStage": {
          "type": "string",
          "enum": ["raw", "normalized", "curated-ui-subset", "source-summary"]
        },
        "rawSnapshotPath": { "type": ["string", "null"] },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
